#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

PID_FILE="h200_web.pid"
LOG_FILE="h200_web.log"
BIND="${H200_WEB_BIND:-0.0.0.0}"
PORT="${H200_WEB_PORT:-8092}"

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "h200_web.py is already running: pid=$pid"
    echo "URL: http://127.0.0.1:$PORT"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

setsid -f .venv/bin/python h200_web.py --bind "$BIND" --port "$PORT" > "$LOG_FILE" 2>&1
sleep 1

pid="$(pgrep -f "h200_web.py --bind $BIND --port $PORT" | head -1 || true)"
if [[ -z "$pid" ]]; then
  echo "Failed to start h200_web.py. Check $LOG_FILE" >&2
  exit 1
fi

echo "$pid" > "$PID_FILE"
echo "Started h200_web.py: pid=$pid"
echo "Log: $LOG_FILE"
echo "URL: http://127.0.0.1:$PORT"
