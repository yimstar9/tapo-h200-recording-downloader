#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

PID_FILE="h200_web.pid"

if [[ ! -f "$PID_FILE" ]]; then
  pid="$(pgrep -f 'h200_web.py --bind 0.0.0.0 --port 8092' | head -1 || true)"
  if [[ -z "$pid" ]]; then
    echo "h200_web.py is not running."
    exit 0
  fi
else
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
fi

if [[ -z "${pid:-}" ]]; then
  rm -f "$PID_FILE"
  echo "h200_web.py is not running."
  exit 0
fi

if kill -0 "$pid" 2>/dev/null; then
  kill "$pid"
  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.2
  done
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid"
  fi
  echo "Stopped h200_web.py: pid=$pid"
else
  echo "h200_web.py is not running."
fi

rm -f "$PID_FILE"
