#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$ROOT/h200_web.pid"
LOG_FILE="$ROOT/h200_web.log"
BIND="${H200_WEB_BIND:-0.0.0.0}"
PORT="${H200_WEB_PORT:-8092}"
DEFAULT_PYTHON="$ROOT/.venv/bin/python"
PYTHON="${H200_WEB_PYTHON:-$DEFAULT_PYTHON}"
TERMUX_PACKAGES=(
  python
  python-cryptography
  ffmpeg
  clang
  make
  pkg-config
  libffi
  openssl
)

read_pid() {
  [[ -f "$PID_FILE" ]] && cat "$PID_FILE" 2>/dev/null || true
}

is_running() {
  local pid
  pid="$(read_pid)"
  [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null
}

ensure_termux_packages() {
  if ! command -v pkg >/dev/null 2>&1; then
    echo "Termux package manager not found: pkg" >&2
    exit 1
  fi

  local package
  local missing=()
  for package in "${TERMUX_PACKAGES[@]}"; do
    if ! dpkg -s "$package" >/dev/null 2>&1; then
      missing+=("$package")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    echo "Installing missing Termux packages: ${missing[*]}"
    pkg update -y
    pkg install -y "${missing[@]}"
  else
    echo "Termux packages are ready."
  fi
}

ensure_python_environment() {
  local system_python
  system_python="$(command -v python || true)"
  if [[ -z "$system_python" ]]; then
    echo "Termux Python was not installed correctly." >&2
    exit 1
  fi

  if [[ ! -x "$PYTHON" ]]; then
    if [[ "$PYTHON" != "$DEFAULT_PYTHON" ]]; then
      echo "Python not found: $PYTHON" >&2
      exit 1
    fi
    echo "Creating .venv with Termux system packages..."
    "$system_python" -m venv --system-site-packages "$ROOT/.venv"
  fi

  if ! "$PYTHON" -c "import cryptography" >/dev/null 2>&1; then
    if [[ "$PYTHON" != "$DEFAULT_PYTHON" ]]; then
      echo "The selected Python cannot import cryptography: $PYTHON" >&2
      exit 1
    fi
    echo "Updating .venv to use Termux system packages..."
    "$system_python" -m venv --upgrade --system-site-packages "$ROOT/.venv"
  fi

  if ! "$PYTHON" -c "import aiofiles, pytapo" >/dev/null 2>&1; then
    echo "Installing Python requirements..."
    "$PYTHON" -m pip install -r "$ROOT/requirements.txt"
  fi

  if ! "$PYTHON" -c "import aiofiles, cryptography, pytapo" >/dev/null 2>&1; then
    echo "Python dependency verification failed." >&2
    exit 1
  fi
  if ! command -v ffmpeg >/dev/null 2>&1; then
    echo "ffmpeg verification failed." >&2
    exit 1
  fi
  echo "Python environment is ready."
}

install_dependencies() {
  ensure_termux_packages
  ensure_python_environment
}

start_server() {
  install_dependencies

  if is_running; then
    echo "h200_web.py is already running: pid=$(read_pid)"
    echo "URL: http://127.0.0.1:$PORT"
    return
  fi

  rm -f "$PID_FILE"

  if command -v termux-wake-lock >/dev/null 2>&1; then
    termux-wake-lock
  fi

  cd "$ROOT"
  nohup "$PYTHON" -u h200_web.py --bind "$BIND" --port "$PORT" \
    >>"$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" >"$PID_FILE"
  sleep 1

  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$PID_FILE"
    command -v termux-wake-unlock >/dev/null 2>&1 && termux-wake-unlock || true
    echo "Failed to start h200_web.py. Check $LOG_FILE" >&2
    exit 1
  fi

  echo "Started h200_web.py: pid=$pid"
  echo "Log: $LOG_FILE"
  echo "URL: http://127.0.0.1:$PORT"
  echo "LAN: http://PHONE_IP:$PORT"
}

stop_server() {
  local pid
  pid="$(read_pid)"
  if ! is_running; then
    rm -f "$PID_FILE"
    echo "h200_web.py is not running."
    return
  fi

  kill "$pid"
  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.2
  done
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid"
  fi

  rm -f "$PID_FILE"
  command -v termux-wake-unlock >/dev/null 2>&1 && termux-wake-unlock || true
  echo "Stopped h200_web.py: pid=$pid"
}

show_status() {
  if is_running; then
    echo "h200_web.py is running: pid=$(read_pid)"
    echo "URL: http://127.0.0.1:$PORT"
  else
    echo "h200_web.py is not running."
    exit 1
  fi
}

case "${1:-start}" in
  install) install_dependencies ;;
  start) start_server ;;
  stop) stop_server ;;
  restart)
    stop_server
    start_server
    ;;
  status) show_status ;;
  *)
    echo "Usage: $0 {install|start|stop|restart|status}" >&2
    exit 2
    ;;
esac
