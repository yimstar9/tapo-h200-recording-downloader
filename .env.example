# Copy to .env manually, or let setup create/update .env automatically:
# .venv/bin/python h200_recordings.py --setup
TAPO_CONFIG=tapo_h200.local.json
TAPO_KEY_FILE=tapo_h200.local.key
TAPO_HUB_HOST=H200_IP
TAPO_USER=admin
TAPO_DEVICE_ID=D230_DEVICE_ID
TAPO_CAMERA_ALIAS=D230_ALIAS

# Prefer storing passwords with:
# .venv/bin/python h200_recordings.py --setup
#
# If you intentionally do not want encrypted local config, these are also supported:
# TAPO_HUB_PASSWORD=
# TAPO_CLOUD_PASSWORD=
