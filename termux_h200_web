#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$ROOT/h200_web.pid"
LOG_FILE="$ROOT/h200_web.log"
BIND="${H200_WEB_BIND:-0.0.0.0}"
PORT="${H200_WEB_PORT:-8092}"
PYTHON="${H200_WEB_PYTHON:-$ROOT/.venv/bin/python}"

read_pid() {
  [[ -f "$PID_FILE" ]] && cat "$PID_FILE" 2>/dev/null || true
}

is_running() {
  local pid
  pid="$(read_pid)"
  [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null
}

start_server() {
  if is_running; then
    echo "h200_web.py is already running: pid=$(read_pid)"
    echo "URL: http://127.0.0.1:$PORT"
    return
  fi

  rm -f "$PID_FILE"
  if [[ ! -x "$PYTHON" ]]; then
    echo "Python not found: $PYTHON" >&2
    echo "Create .venv first, or set H200_WEB_PYTHON." >&2
    exit 1
  fi

  if command -v termux-wake-lock >/dev/null 2>&1; then
    termux-wake-lock
  fi

  cd "$ROOT"
  nohup "$PYTHON" h200_web.py --bind "$BIND" --port "$PORT" \
    >>"$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" >"$PID_FILE"
  sleep 1

  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$PID_FILE"
    command -v termux-wake-unlock >/dev/null 2>&1 && termux-wake-unlock || true
    echo "Failed to start h200_web.py. Check $LOG_FILE" >&2
    exit 1
  fi

  echo "Started h200_web.py: pid=$pid"
  echo "Log: $LOG_FILE"
  echo "URL: http://127.0.0.1:$PORT"
  echo "LAN: http://PHONE_IP:$PORT"
}

stop_server() {
  local pid
  pid="$(read_pid)"
  if ! is_running; then
    rm -f "$PID_FILE"
    echo "h200_web.py is not running."
    return
  fi

  kill "$pid"
  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.2
  done
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid"
  fi

  rm -f "$PID_FILE"
  command -v termux-wake-unlock >/dev/null 2>&1 && termux-wake-unlock || true
  echo "Stopped h200_web.py: pid=$pid"
}

show_status() {
  if is_running; then
    echo "h200_web.py is running: pid=$(read_pid)"
    echo "URL: http://127.0.0.1:$PORT"
  else
    echo "h200_web.py is not running."
    exit 1
  fi
}

case "${1:-start}" in
  start) start_server ;;
  stop) stop_server ;;
  restart)
    stop_server
    start_server
    ;;
  status) show_status ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}" >&2
    exit 2
    ;;
esac
